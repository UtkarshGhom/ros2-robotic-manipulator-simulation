<?xml version="1.0" ?>
<robot name="robotic_arm" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <material name="silver">
    <color rgba="0.700 0.700 0.700 1.000"/>
  </material>

  <link name="world"/>
  
  <joint name="virtual_joint" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="-2.007e-15 0.00109 0.0221" rpy="0 0 0"/>
      <mass value="0.7425"/>
      <inertia ixx="0.001058" iyy="0.001012" izz="0.001614" ixy="0" iyz="0" ixz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="link_1_1">
    <inertial>
      <origin xyz="0.00749 0.00142 0.0193" rpy="0 0 0"/>
      <mass value="0.5781"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" iyz="0" ixz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.056" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/link_1_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.056" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/link_1_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="link_2_1">
    <inertial>
      <origin xyz="-0.0077 0.06 0" rpy="0 0 0"/>
      <mass value="0.5029"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" iyz="0" ixz="0"/>
    </inertial>
    <visual>
      <origin xyz="-0.004 -0.01391 -0.09628" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/link_2_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="-0.004 -0.01391 -0.09628" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/link_2_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="link_3_1">
    <inertial>
      <origin xyz="0.0057 0.0417 0" rpy="0 0 0"/>
      <mass value="0.3697"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" iyz="0" ixz="0"/>
    </inertial>
    <visual>
      <origin xyz="-0.004 -0.13391 -0.09628" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/link_3_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="-0.004 -0.13391 -0.09628" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/link_3_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="link_4_1">
    <inertial>
      <origin xyz="0.0052 0.0178 0.005" rpy="0 0 0"/>
      <mass value="0.1292"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" iyz="0" ixz="0"/>
    </inertial>
    <visual>
      <origin xyz="-0.0095 -0.22366 -0.10158" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/link_4_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="-0.0095 -0.22366 -0.10158" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/link_4_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="Gripper_Base_1">
    <inertial>
      <origin xyz="-0.0041 0.0249 0.0064" rpy="0 0 0"/>
      <mass value="0.1259"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" iyz="0" ixz="0"/>
    </inertial>
    <visual>
      <origin xyz="-0.0235 -0.25166 -0.10658" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/Gripper_Base_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="-0.0235 -0.25166 -0.10658" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/Gripper_Base_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="gear_L_1">
    <inertial>
      <origin xyz="-0.0055 0.0005 0.002" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" iyz="0" ixz="0"/>
    </inertial>
    <visual>
      <origin xyz="-0.0056 -0.28966 -0.12058" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/gear_L_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="-0.0056 -0.28966 -0.12058" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/gear_L_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="gear_R_1">
    <inertial>
      <origin xyz="0.0053 0.0005 0.002" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" iyz="0" ixz="0"/>
    </inertial>
    <visual>
      <origin xyz="-0.0325 -0.28966 -0.12058" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/gear_R_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="-0.0325 -0.28966 -0.12058" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/gear_R_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="Gripper_L_1">
    <inertial>
      <origin xyz="0.0033 -0.0255 -0.0022" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" iyz="0" ixz="0"/>
    </inertial>
    <visual>
      <origin xyz="0.02515 -0.28966 -0.12058" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/Gripper_L_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0.02515 -0.28966 -0.12058" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/Gripper_L_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="Gripper_R_1">
    <inertial>
      <origin xyz="-0.0033 -0.0255 -0.0022" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" iyz="0" ixz="0"/>
    </inertial>
    <visual>
      <origin xyz="-0.06325 -0.28966 -0.12058" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/Gripper_R_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="-0.06325 -0.28966 -0.12058" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/Gripper_R_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_1" type="revolute">
    <origin xyz="0 0 0.056" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="link_1_1"/>
    <axis xyz="0 0 1"/>
    <limit upper="5.934" lower="0.0" effort="100" velocity="100"/>
  </joint>

  <joint name="joint_2" type="revolute">
    <origin xyz="0.004 0.01391 0.04028" rpy="0 0 0"/>
    <parent link="link_1_1"/>
    <child link="link_2_1"/>
    <axis xyz="1 0 0"/>
    <limit upper="3.403" lower="-0.436" effort="100" velocity="100"/>
  </joint>

  <joint name="joint_3" type="revolute">
    <origin xyz="0 0.12 0" rpy="0 0 0"/>
    <parent link="link_2_1"/>
    <child link="link_3_1"/>
    <axis xyz="-1 0 0"/>
    <limit upper="2.356" lower="-2.443" effort="100" velocity="100"/>
  </joint>

  <joint name="joint_4" type="revolute">
    <origin xyz="0.0055 0.08975 0.0053" rpy="0 0 0"/>
    <parent link="link_3_1"/>
    <child link="link_4_1"/>
    <axis xyz="0 1 0"/>
    <limit upper="6.108" lower="0.0" effort="100" velocity="100"/>
  </joint>

  <joint name="joint_5" type="revolute">
    <origin xyz="0.014 0.028 0.005" rpy="0 0 0"/>
    <parent link="link_4_1"/>
    <child link="Gripper_Base_1"/>
    <axis xyz="-1 0 0"/>
    <limit upper="2.268" lower="-1.919" effort="100" velocity="100"/>
  </joint>

  <joint name="gripper_left_joint" type="revolute">
    <origin xyz="-0.0179 0.038 0.014" rpy="0 0 0"/>
    <parent link="Gripper_Base_1"/>
    <child link="gear_L_1"/>
    <axis xyz="0 0 1"/>
    <limit upper="0.087" lower="-1.570" effort="100" velocity="100"/>
  </joint>

  <joint name="gripper_right_joint" type="revolute">
    <origin xyz="0.009 0.038 0.014" rpy="0 0 0"/>
    <parent link="Gripper_Base_1"/>
    <child link="gear_R_1"/>
    <axis xyz="0 0 1"/>
    <limit upper="1.570" lower="-0.087" effort="100" velocity="100"/>
    <mimic joint="gripper_left_joint" multiplier="-1.0" offset="0" />
  </joint>

  <joint name="finger_left_joint" type="revolute">
    <origin xyz="-0.03075 0 0" rpy="0 0 0"/>
    <parent link="gear_L_1"/>
    <child link="Gripper_L_1"/>
    <axis xyz="0 0 -1"/>
    <limit upper="6.28" lower="-6.28" effort="100" velocity="100"/>
  </joint>

  <joint name="finger_right_joint" type="revolute">
    <origin xyz="0.03075 0 0" rpy="0 0 0"/>
    <parent link="gear_R_1"/>
    <child link="Gripper_R_1"/>
    <axis xyz="0 0 1"/>
    <limit upper="6.28" lower="-6.28" effort="100" velocity="100"/>
    <mimic joint="finger_left_joint" multiplier="1.0" offset="0" />
  </joint>

  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>
    <joint name="joint_1">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
    <joint name="joint_2">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
    <joint name="joint_3">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
    <joint name="joint_4">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
    <joint name="joint_5">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
    <joint name="gripper_left_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
    <joint name="gripper_right_joint">
      <param name="mimic">gripper_left_joint</param>
      <param name="multiplier">-1.0</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
    <joint name="finger_left_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
    <joint name="finger_right_joint">
      <param name="mimic">finger_left_joint</param>
      <param name="multiplier">1.0</param>
      <command_interface name="position"/>
      <state_interface name="position"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <parameters>$(find robotic_arm_description)/config/my_controllers.yaml</parameters>
    </plugin>
  </gazebo>

</robot>
